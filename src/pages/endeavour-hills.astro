---
import Layout from '../layouts/Layout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Is Endeavour Hills reactive clay?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes — Endeavour Hills is part of the same Newer Volcanic clay belt that runs through Hallam and Hampton Park. Most blocks rate AS 2870 Class M to H1, with 30-50mm seasonal swell. The hilly topography (the suburb is genuinely on the hills above Dandenong) makes it worse in places where natural drainage concentrates run-off into a few yards. Sub-base, drainage and footing depth all need to be over-engineered relative to flat sandy sites." }
    },
    {
      "@type": "Question",
      "name": "What earthworks jobs do you do most in Endeavour Hills?",
      "acceptedAnswer": { "@type": "Answer", "text": "Driveway replacements (original 1980s sub-base failures), pool excavations on established blocks, extension and granny-flat footings, drainage retrofits for sloping or low-lying yards, retaining-wall trenches. Almost every job involves working with the slope — Endeavour Hills isn't a flat suburb. We bring the right gear for benching, battering and stair-step excavation." }
    },
    {
      "@type": "Question",
      "name": "How do you handle sloping Endeavour Hills blocks?",
      "acceptedAnswer": { "@type": "Answer", "text": "Sloping blocks need benched or stepped excavation rather than a flat cut. We start from the high side, cut a level bench wide enough for the slab, then drop down to the next bench. Battered shoulders on cuts above 600mm to prevent collapse — Worksafe requires 1:1 slope on unsupported sandy clay, 1:0.75 on stiffer clay. Where shoring or retaining is needed we coordinate the wall builder before any cuts happen." }
    },
    {
      "@type": "Question",
      "name": "Can you do retaining-wall footings in Endeavour Hills?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes — retaining-wall footing trenches are common in Endeavour Hills because of the slopes. A typical 12-15m retaining wall on a sloping back yard needs a 600-800mm wide trench, 600-1200mm deep depending on retained height, with the trench bottom level for the wall builder's first course or footing pour. $1,500-$3,500 for the trench depending on length and depth. We coordinate timing with the wall builder so the trench doesn't sit open through wet weather." }
    },
    {
      "@type": "Question",
      "name": "Do Endeavour Hills jobs need extra drainage work?",
      "acceptedAnswer": { "@type": "Answer", "text": "Almost always. The slope means surface water moves fast and concentrates into a few low points. Without proper subsoil drainage and slab-edge drains, that water sits under driveways and slabs and accelerates the clay-swell cracking. We typically install 100-150mm slotted ag-line along the high side of any new driveway or slab, with sump pits at any low-point, all draining to a legal stormwater connection. Adds $1,200-$2,800 to a typical job but adds 10-15 years to the life of the slab." }
    },
    {
      "@type": "Question",
      "name": "What does a typical driveway replacement cost in Endeavour Hills?",
      "acceptedAnswer": { "@type": "Answer", "text": "A typical 60m2 driveway replacement on a sloping Endeavour Hills block — strip old slab, excavate to firm sub-grade, lay 180-200mm crushed-rock sub-base, install edge drainage, compact in 100mm lifts — runs $5,500-$9,500. That's not including the concrete pour, which the concreter quotes separately ($90-$120/m2 typical). Cheaper quotes you'll see usually skip the proper sub-base depth and edge drainage — that's why those driveways crack in 5 years." }
    }
  ]
};
---
<Layout
  title="Excavation & Bobcat Hire Endeavour Hills | Sloping Clay-Belt Sites | (03) 9003 0108"
  description="Excavation, bobcat hire and civil site-prep in Endeavour Hills — sloping reactive-clay specialists. Driveway prep, footings, retaining-wall trenches, pool digs, drainage retrofits. Free on-site quote."
  canonical="https://caseyearthworks.com.au/endeavour-hills/">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <section class="hero">
    <div class="hero-inner">
      <span class="hero-eyebrow">Endeavour Hills &middot; sloping clay-belt territory</span>
      <h1>Excavation &amp; bobcat hire in <span class="accent">Endeavour Hills</span>.</h1>
      <p class="hero-sub">
        Endeavour Hills is sloping reactive-clay territory &mdash; the same Class M
        to H1 Newer Volcanic clay as Hallam and Hampton Park, but with hills that
        concentrate run-off and demand benched, battered, properly-drained
        excavation. We&rsquo;ve been digging here for two decades and know the
        ground block by block.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="tel:+61390030108">&#9742; Call (03) 9003 0108</a>
        <a class="btn btn-ghost" href="/quote/">Book a free site visit</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <span class="section-eyebrow">Why Endeavour Hills</span>
      <h2>The Endeavour Hills earthworks story.</h2>
      <div class="divider"></div>
      <div style="max-width: 65rem;">
        <h3>Slope changes everything.</h3>
        <p>
          Endeavour Hills is genuinely on the hills above Dandenong &mdash;
          most blocks have at least one direction of fall. Excavation here is
          benched or stair-step rather than a single flat cut. Worksafe rules on
          unsupported batter slopes (1:1 on sandy clay, 1:0.75 on stiff clay)
          dictate cut geometry. Anything steeper needs shoring, soldier piles
          or retaining. We design the cut sequence at quoting so the right gear
          is on site &mdash; bobcats and mini-ex for tight bench work, bigger
          excavators for the bulk cuts on larger blocks.
        </p>

        <h3 style="margin-top: 2rem;">Drainage is non-negotiable here.</h3>
        <p>
          Slope concentrates run-off, and reactive clay swells where the water
          sits. The two together explain why so many Endeavour Hills slabs
          and driveways move within 10 years. Every job we do here includes
          proper sub-soil drainage planning &mdash; 100&ndash;150mm slotted
          ag-line along the high side of slabs and driveways, sump pits at
          low points, all running to a legal stormwater discharge. Adds
          $1,200&ndash;$2,800 but adds a decade or more to slab life.
        </p>

        <h3 style="margin-top: 2rem;">Retaining-wall trenches are routine.</h3>
        <p>
          Sloping blocks mean retaining walls almost everywhere &mdash; under the
          driveway, between the yard levels, sometimes a series of stepped walls
          to break a 2m fall. We trench the footing line at the spec required by
          the wall engineer (typically 600&ndash;800mm wide, 600&ndash;1200mm
          deep depending on retained height), keep the trench level for the
          wall builder, and coordinate the timing so the trench doesn&rsquo;t sit
          open through a wet week.
        </p>

        <h3 style="margin-top: 2rem;">Typical Endeavour Hills jobs.</h3>
        <ul>
          <li>Driveway replacement on a sloping block with edge drainage ($5.5K&ndash;$9.5K)</li>
          <li>Pool excavation on stepped rear yard with shotcrete-coordinated dig ($4.5K&ndash;$7K)</li>
          <li>Retaining-wall footing trench, 12&ndash;15m run ($1.5K&ndash;$3.5K)</li>
          <li>Granny-flat or extension footings with piered design ($2.8K&ndash;$5K)</li>
          <li>Sub-soil drainage retrofit on existing slab ($2.8K&ndash;$5.5K)</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="section-inner">
      <h2>Other service areas.</h2>
      <div class="areas-grid">
        <a class="area-pill" href="/berwick/">Berwick</a>
        <a class="area-pill" href="/cranbourne/">Cranbourne</a>
        <a class="area-pill" href="/narre-warren/">Narre Warren</a>
        <a class="area-pill" href="/hampton-park/">Hampton Park</a>
        <a class="area-pill" href="/city-of-casey/">All City of Casey</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <div class="cta-block">
        <h2>Free Endeavour Hills site visit.</h2>
        <p>Slope, soil, drainage check. Honest call on what your sub-base actually needs to outlast the clay.</p>
        <div class="hero-actions" style="justify-content:center;">
          <a class="btn btn-primary" href="tel:+61390030108">&#9742; Call (03) 9003 0108</a>
          <a class="btn btn-ghost" href="/quote/">Book online</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
