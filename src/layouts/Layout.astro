  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <div>
        <h4>Casey Earthworks</h4>
        <p style="margin-bottom: 0.75rem;">Owner-operator excavation, bobcat hire and civil site-prep across the City of Casey — Berwick, Cranbourne, Narre Warren, Hampton Park, Endeavour Hills. Site cut and fill, driveway sub-base, footings, pool digs, drainage trenching. AS 3798 compliant, Worksafe VIC, fully insured.</p>
        <p style="margin-bottom: 0.5rem;"><strong style="color:#fff;">Phone:</strong> <a href={`tel:${PHONE_TEL}`}>{PHONE_DISPLAY}</a></p>
        <p style="margin-bottom: 0.5rem;"><strong style="color:#fff;">Hours:</strong> Mon&ndash;Sat 7am&ndash;6pm</p>
        <p style="margin-bottom: 0.5rem;"><strong style="color:#fff;">Service area:</strong> Berwick VIC 3806 &amp; City of Casey LGA</p>
      </div>
      <div>
        <h4>Services</h4>
        <ul>
          <li><a href="/services/site-cut-and-fill/">Site cut &amp; fill</a></li>
          <li><a href="/services/driveway-preparation/">Driveway preparation</a></li>
          <li><a href="/services/foundation-excavation/">Foundation excavation</a></li>
          <li><a href="/services/pool-excavation/">Pool excavation</a></li>
          <li><a href="/services/drainage-trenching/">Drainage trenching</a></li>
        </ul>
      </div>
      <div>
        <h4>Service Areas</h4>
        <ul>
          <li><a href="/berwick/">Berwick</a></li>
          <li><a href="/cranbourne/">Cranbourne</a></li>
          <li><a href="/narre-warren/">Narre Warren</a></li>
          <li><a href="/hampton-park/">Hampton Park</a></li>
          <li><a href="/endeavour-hills/">Endeavour Hills</a></li>
          <li><a href="/city-of-casey/">All City of Casey</a></li>
        </ul>
      </div>
