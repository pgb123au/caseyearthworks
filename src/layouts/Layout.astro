    <p class="footer-bottom">
      &copy; {new Date().getFullYear()} {BIZ_NAME} &middot; Yes Right Pty Ltd ABN 91 664 546 061. Owner-operated excavation, bobcat hire &amp; civil site prep across the City of Casey.
     &middot; <a href="/about/">About</a> &middot; <a href="/privacy/">Privacy</a></p>
  </footer>

  <a class="mobile-phone" href={`tel:${PHONE_TEL}`} aria-label={`Call ${PHONE_DISPLAY}`}>
    <span aria-hidden="true">&#9742;</span> Call {PHONE_DISPLAY}
