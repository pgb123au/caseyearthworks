---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogType?: string;
}

const SITE = 'https://caseyearthworks.com.au';
const PHONE_DISPLAY = '(03) 9003 0108';
const PHONE_TEL = '+61390030108';
const EMAIL = 'quotes@caseyearthworks.com.au';
const BIZ_NAME = 'Casey Earthworks';

const { title, description, canonical = SITE + '/', ogType = 'website' } = Astro.props;

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "GeneralContractor",
  "@id": SITE + "/#business",
  "name": BIZ_NAME,
  "image": SITE + "/images/og-image.jpg",
  "url": SITE,
  "telephone": PHONE_TEL,
  "priceRange": "$$",
  "description": "Owner-operator excavation, bobcat hire and civil site-prep contractors serving Berwick, Cranbourne, Narre Warren, Hampton Park and Endeavour Hills. Site cut and fill, driveway sub-base, footing and pool digs, stormwater and service trenching. AS 3798 earthworks, Worksafe VIC compliant, fully insured.",
  "areaServed": [
    { "@type": "City", "name": "Berwick", "containedInPlace": { "@type": "AdministrativeArea", "name": "City of Casey" } },
    { "@type": "City", "name": "Cranbourne" },
    { "@type": "City", "name": "Narre Warren" },
    { "@type": "City", "name": "Hampton Park" },
    { "@type": "City", "name": "Endeavour Hills" },
    { "@type": "City", "name": "Officer" },
    { "@type": "City", "name": "Clyde" },
    { "@type": "City", "name": "Pakenham" },
    { "@type": "City", "name": "Hallam" }
  ],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Berwick",
    "addressRegion": "VIC",
    "postalCode": "3806",
    "addressCountry": "AU"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -38.0395,
    "longitude": 145.3458
  },
  "openingHoursSpecification": [{
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
    "opens": "07:00",
    "closes": "18:00"
  }],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Excavation, Bobcat Hire & Civil Site Prep Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Site Cut and Fill" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Driveway Preparation" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Foundation Excavation" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Pool Excavation" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Drainage Trenching" }}
    ]
  }
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": SITE + "/#website",
  "url": SITE + "/",
  "name": BIZ_NAME,
  "inLanguage": "en-AU",
  "publisher": { "@id": SITE + "/#business" }
};
// BreadcrumbList JSON-LD auto-generated from Astro.url.pathname
const pathname = Astro.url.pathname;
const breadcrumbSegments = pathname.split('/').filter(Boolean);
const breadcrumbItems = [{ "@type": "ListItem", "position": 1, "name": "Home", "item": SITE + "/" }];
let cumulative = SITE;
breadcrumbSegments.forEach((seg, i) => {
  cumulative += '/' + seg;
  // Human-friendly name: kebab → Title Case, special-case 'services' → Services
  const friendly = seg === 'services'
    ? 'Services'
    : seg.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
  breadcrumbItems.push({
    "@type": "ListItem",
    "position": i + 2,
    "name": friendly,
    "item": cumulative + '/'
  });
});
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems
};

---
<!DOCTYPE html>
<html lang="en-AU">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={canonical}>
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
  <meta name="theme-color" content="#3B2A18">

  <meta property="og:type" content={ogType}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={canonical}>
  <meta property="og:locale" content="en_AU">
  <meta property="og:site_name" content={BIZ_NAME}>
  <meta property="og:image" content={SITE + "/images/og-image.jpg"}>
  <meta property="og:image:secure_url" content={SITE + "/images/og-image.jpg"}>
  <meta property="og:image:type" content="image/jpeg">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content={BIZ_NAME + " — free quote, call today"}>

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={SITE + "/images/og-image.jpg"}>
  <meta name="twitter:image:alt" content={BIZ_NAME + " — free quote, call today"}>

  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;800&family=Playfair+Display:wght@900&family=Stardos+Stencil:wght@700&display=swap">

  <meta name="google-site-verification" content="NcHyUdUlpAh7C4rMei2M6WYJ3sfJjEwK_YP7WgsWtmQ">

  <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-XXXXXXXXXX', {
      'send_page_view': true,
      'anonymize_ip': true
    });
  </script>

  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <slot name="head" />
</head>
<body class="site-caseyearthworks narrative-after_hours fv-1">
  <div class="top-bar">
    <span>Owner-operated &middot; Berwick &middot; Cranbourne &middot; Narre Warren &middot; Call <a href={`tel:${PHONE_TEL}`}>{PHONE_DISPLAY}</a></span>
  </div>

  <header class="site-header">
    <div class="nav-wrap">
      <a class="brand" href="/" aria-label="Casey Earthworks home">
        <img src="/images/logo.svg" alt="Casey Earthworks" width="320" height="80" decoding="async">
      </a>
      <ul class="nav-links">
        <li><a href="/services/site-cut-and-fill/">Site Cut &amp; Fill</a></li>
        <li><a href="/services/driveway-preparation/">Driveway Prep</a></li>
        <li><a href="/services/foundation-excavation/">Foundations</a></li>
        <li><a href="/services/pool-excavation/">Pool Digs</a></li>
        <li><a href="/services/drainage-trenching/">Drainage</a></li>
        <li><a href="/city-of-casey/">Areas</a></li>
      </ul>
      <a class="nav-cta" href="/quote/">Free Site Visit</a>
    </div>
